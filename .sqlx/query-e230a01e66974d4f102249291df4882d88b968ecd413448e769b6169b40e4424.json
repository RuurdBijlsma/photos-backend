  "query": "SELECT \n               f.id, \n               va.media_item_id, \n               f.embedding as \"embedding!: Vector\", \n               f.position_x, \n               f.position_y, \n               f.width, \n               f.height,\n               va.percentage\n           FROM face f\n           JOIN visual_analysis va ON f.visual_analysis_id = va.id\n           JOIN media_item mi ON mi.id = va.media_item_id\n           WHERE mi.user_id = $1",
