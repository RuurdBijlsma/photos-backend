  "query": "\n        SELECT\n            id,\n            is_video,\n            has_thumbnails,\n            duration_ms::INT AS duration_ms,\n            (width::real / height::real) AS \"ratio!\"\n        FROM media_item\n        WHERE user_id = $1 AND deleted = true\n        ORDER BY sort_timestamp DESC\n        ",
